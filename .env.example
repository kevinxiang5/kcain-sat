# Database
# SQLite (easiest for local dev - no setup required):
# DATABASE_URL="file:./dev.db"
# PostgreSQL (for production):
# DATABASE_URL="postgresql://user:password@localhost:5432/sat_learning?schema=public"
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-secret-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Email (Resend) - verification & password reset
# See RESEND_SETUP.md for step-by-step setup
RESEND_API_KEY="re_xxxxxxxxxxxx"
# Optional: custom sender (must verify domain in Resend). Default: Cain <onboarding@resend.dev>
# EMAIL_FROM="Cain <noreply@cainsat.org>"

# Firebase - Google sign-in uses the kalshi-nono Firebase project
